{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"moduleResolution": "Node16",
		"sourceMap": true,
		"rootDir": ".",
		"outDir": "out",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node", "vscode", "bun-types"]
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
